      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "email",
      "value": "admin@example.com",
      "type": "string"
    },
    {
      "key": "password",
      "value": "Admin1234!",
      "type": "string"
    }
